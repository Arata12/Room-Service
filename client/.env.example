# Client Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# STRIPE (REQUIRED)
# =============================================================================
# Get your publishable key from: https://dashboard.stripe.com/apikeys
# This is the public key that can be safely exposed to the browser
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here
VITE_TEST_MODE=true

# =============================================================================
# API URL
# =============================================================================
# URL where the backend API is running
# For local development: http://localhost:3001
# For Docker: http://localhost:3001 (when accessing from host)
VITE_API_URL=http://localhost:3001
