# Server Configuration

# Server
PORT=3001
NODE_ENV=development

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection settings
# For Docker: use 'postgres' as host (service name)
# For local dev: use 'localhost'
DB_HOST=postgres
DB_PORT=5432
DB_NAME=roomservice
DB_USER=admin
DB_PASSWORD=secret

# =============================================================================
# STRIPE (REQUIRED for payments)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys for development, live keys for production

# Secret key (server-side only, never expose to client)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Webhook secret (for verifying Stripe webhooks)
# Get this from: Stripe Dashboard > Developers > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public key (used by server for reference)
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# Test mode - skips Stripe payments for demo purposes
TEST_MODE=true

# =============================================================================
# THERMAL PRINTER (Optional - for kitchen receipts)
# =============================================================================
# ESC/POS network printer configuration
# Leave empty to disable printing

# Printer IP address (e.g., 192.168.1.100)
PRINTER_HOST=

# Printer port (default 9100 for most network printers)
PRINTER_PORT=9100

# =============================================================================
# CURRENCY SETTINGS
# =============================================================================
# Default currency for display and processing
DEFAULT_CURRENCY=USD

# Exchange rate for MXN conversions
USD_TO_MXN_RATE=17.50

# =============================================================================
# CLIENT ENVIRONMENT (for client/.env)
# =============================================================================
# These are used when building the client
# Copy these to client/.env or set in docker-compose

# Stripe public key for client-side payment forms
VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# API URL for client to connect to backend
VITE_API_URL=http://localhost:3001
